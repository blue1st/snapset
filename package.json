{
  "name": "snapset",
  "version": "1.1.1",
  "build": {
    "appId": "com.blue1st.snapset",
    "mac": {
      "identity": null,
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "directories": {
      "output": "dist"
    }
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder",
    "release": "release-it"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "release-it": "^17.10.1",
    "@release-it/conventional-changelog": "^8.0.2",
    "conventional-commits-filter": "^5.0.0",
    "conventional-commits-parser": "^6.4.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "fs-extra": "^11.2.0",
    "screenshot-desktop": "^1.15.4",
    "sharp": "^0.33.3"
  }
}
